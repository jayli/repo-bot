{
  "name": "repo-bot",
  "private": true,
  "scripts": {
    "init": "test -f .env || cp .env.example .env; test -f config/sourcebot.json || cp config/sourcebot.json.example config/sourcebot.json; echo '配置已初始化，请编辑 .env 和 config/sourcebot.json'",
    "dev": "bash scripts/dev-chat-ui.sh",
    "deploy": "docker compose up -d --no-deps --build chat-ui",
    "deploy:chat-ui": "docker compose up -d --no-deps --build chat-ui",
    "deploy:ast-service": "docker compose up -d --no-deps --build ast-service",
    "deploy:all": "docker compose up -d --build",
    "up": "docker compose up -d",
    "down": "docker compose down",
    "restart": "docker compose down && docker compose up -d",
    "logs": "docker compose logs -f",
    "ps": "docker compose ps",
    "index:qdrant": "docker cp chat-ui/index_code.py repo-bot-chat-ui-1:/app/index_code.py && docker exec repo-bot-chat-ui-1 python /app/index_code.py",
    "index:qdrant:incr": "docker cp chat-ui/index_code.py repo-bot-chat-ui-1:/app/index_code.py && docker exec repo-bot-chat-ui-1 python /app/index_code.py --incremental",
    "search": "python3 scripts/index-vectors.py --search",
    "open": "open http://localhost:8501",
    "open:sourcebot": "open http://localhost:3000",
    "open:qdrant": "open http://localhost:6333/dashboard",
    "index:ast": "docker exec repo-bot-ast-service-1 python /app/indexer.py --mode full",
    "index:ast:incr": "docker exec repo-bot-ast-service-1 python /app/indexer.py --mode incremental",
    "open:ast": "open http://localhost:8502/docs",
    "open:neo4j": "open http://localhost:7474",
    "dev:ast": "bash scripts/dev-ast-service.sh",
    "index:graph": "docker compose exec -T ast-service python /app/graph_cli.py sync",
    "index:graph:incr": "docker compose exec -T ast-service python /app/graph_cli.py sync-incr",
    "index:sourcebot": "docker compose restart sourcebot",
    "index:sourcebot:incr": "docker compose restart sourcebot",
    "sync:sourcebot": "bash scripts/sync-sourcebot.sh",
    "clean": "docker image prune -f",
    "build_push:chat-ui": "bash scripts/docker-build-push.sh chat-ui",
    "build_push:ast-service": "bash scripts/docker-build-push.sh ast-service",
    "build_push:chat-ui:arm": "bash scripts/docker-build-push.sh chat-ui arm64",
    "build_push:chat-ui:x86": "bash scripts/docker-build-push.sh chat-ui amd64",
    "build_push:ast-service:arm": "bash scripts/docker-build-push.sh ast-service arm64",
    "build_push:ast-service:x86": "bash scripts/docker-build-push.sh ast-service amd64",
    "build_push:chat-ui:all": "bash scripts/docker-build-push.sh chat-ui all",
    "build_push:ast-service:all": "bash scripts/docker-build-push.sh ast-service all",
    "docker_push:chat-ui": "bash scripts/docker-push-existing.sh chat-ui",
    "docker_push:ast-service": "bash scripts/docker-push-existing.sh ast-service",
    "install": "bash scripts/install.sh"
  }
}
