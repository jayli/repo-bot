# LLM 配置（Ask Sourcebot + Chat UI 共用）
# 支持: anthropic, openai, bedrock, vertex
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://your-proxy.example.com:996
# ANTHROPIC_MAX_TOKENS=24576
# OPENAI_API_KEY=sk-...

# === Embedding 配置（OpenAI 兼容接口） ===
# 模型名，如 text-embedding-v4 / text-embedding-3-large / bge-m3
EMBEDDING_MODEL=text-embedding-v4
# Embedding 维度，默认 1024（与 text-embedding-v4 匹配）
EMBEDDING_DIM=1024
# Embedding API 地址，默认阿里云 DashScope
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Embedding API Key（留空则复用 LLM 的 API_KEY）
EMBEDDING_API_KEY=sk-...

# Qdrant 向量库
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=codebase

# Sourcebot
SOURCEBOT_URL=http://localhost:3000
SOURCEBOT_ORG_DOMAIN=~
# 在 Sourcebot 设置页创建 API Key 后填入，Chat UI 后台搜索需要它
# SOURCEBOT_API_KEY=sb_...

# Chat UI 登录鉴权
CHAT_USERNAME=admin
CHAT_PASSWORD=admin123

# ast-grep 结构索引服务
AST_SERVICE_URL=http://localhost:8502

# Neo4j 图关系索引
NEO4J_ENABLED=true
NEO4J_IMAGE=neo4j:5-community
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=repo-bot-neo4j
NEO4J_DATABASE=neo4j
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=2G
NEO4J_PAGECACHE=1G

# 启用 LLM 二次规划（Round 1 检索后注入上下文让 LLM 精排，默认关闭）
# LLM_PLANNER_ENABLED=true

# 代码仓库根目录（挂载到容器内）
REPOS_ROOT=~/projects
